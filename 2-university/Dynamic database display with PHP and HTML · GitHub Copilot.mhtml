&lt;html&gt;
&lt;head&gt;
    &lt;title&gt;Instructor<span class=3D"hljs-string" node=3D"[object Obje=
ct]">'s Courses&lt;/title&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;Enter Instructor Name&lt;/h1&gt;
    &lt;form method=3D"post"&gt;
        &lt;label for=3D"instructor"&gt;Instructor Name:&lt;/label&gt;
        &lt;input type=3D"text" id=3D"instructor" name=3D"instructor" value=
=3D"Luis Jaimes"&gt;
        &lt;button type=3D"submit" name=3D"search"&gt;Search Courses&lt;/bu=
tton&gt;
    &lt;/form&gt;

    &lt;?php
    if (isset($_POST['</span>search<span class=3D"hljs-string" node=3D"[obj=
ect Object]">'])) {
        $instructor =3D $_POST['</span>instructor<span class=3D"hljs-string=
" node=3D"[object Object]">'];
        displayCourses($instructor);
    }

    function displayCourses($instructor) {
        // Path to your SQL file
        $sqlFile =3D '</span>courses.sql<span class=3D"hljs-string" node=3D=
"[object Object]">';

        if (file_exists($sqlFile)) {
            $sql =3D file_get_contents($sqlFile);

            // Establishing database connection
            $servername =3D "your_servername";
            $username =3D "your_username";
            $password =3D "your_password";
            $dbname =3D "your_dbname";

            try {
                $conn =3D new PDO("mysql:host=3D$servername;dbname=3D$dbnam=
e", $username, $password);
                $conn-&gt;setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCE=
PTION);

                // Execute SQL script
                $stmt =3D $conn-&gt;prepare($sql);
                $stmt-&gt;execute();

                // Fetch courses taught by the instructor
                $query =3D "SELECT * FROM courses WHERE instructor =3D :ins=
tructor";
                $stmt =3D $conn-&gt;prepare($query);
                $stmt-&gt;bindParam('</span>:instructor<span class=3D"hljs-=
string" node=3D"[object Object]">', $instructor);
                $stmt-&gt;execute();
                $courses =3D $stmt-&gt;fetchAll(PDO::FETCH_ASSOC);

                if ($courses) {
                    echo "&lt;h2&gt;Courses Taught by $instructor&lt;/h2&gt=
;";
                    echo "&lt;table border=3D'</span><span class=3D"hljs-nu=
mber" node=3D"[object Object]">1</span><span class=3D"hljs-string" node=3D"=
[object Object]">'&gt;";
                    echo "&lt;tr&gt;&lt;th&gt;Course ID&lt;/th&gt;&lt;th&gt=
;Course Name&lt;/th&gt;&lt;th&gt;Instructor&lt;/th&gt;&lt;/tr&gt;";
                    foreach ($courses as $course) {
                        echo "&lt;tr&gt;";
                        echo "&lt;td&gt;" . $course['</span>course_id<span =
class=3D"hljs-string" node=3D"[object Object]">'] . "&lt;/td&gt;";
                        echo "&lt;td&gt;" . $course['</span>course_name<spa=
n class=3D"hljs-string" node=3D"[object Object]">'] . "&lt;/td&gt;";
                        echo "&lt;td&gt;" . $course['</span>instructor<span=
 class=3D"hljs-string" node=3D"[object Object]">'] . "&lt;/td&gt;";
                        echo "&lt;/tr&gt;";
                    }
                    echo "&lt;/table&gt;";
                } else {
                    echo "No courses found for instructor $instructor.";
                }
            } catch (PDOException $e) {
                echo "Connection failed: " . $e-&gt;getMessage();
            }

            $conn =3D null;
        } else {
